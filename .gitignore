# ============================================================
# .gitignore — 입찰메이트 RFP RAG (Codeit Part3 Team5)
# ============================================================

# === 환경변수 / 시크릿 (절대 커밋 금지) ===
.env
.env.*
**/.env
*.key
*-key.json

# === Python ===
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
*.pkl
dist/
build/

# === 가상환경 ===
.venv/
venv/
env/
venv-gen/

# === Node (챗봇 프론트엔드용) ===
node_modules/

# === IDE / 에디터 ===
.vscode/

# === OS ===
.DS_Store
Thumbs.db

# === Jupyter ===
.ipynb_checkpoints/

# === 로그 ===
*.log

# === 벡터 DB / 인덱스 (용량 크고 재생성 가능) ===
*.faiss
*.index
data/vector_db/
data/faiss_index/
vector_store/

# === NDA: 원본 RFP 데이터 (커밋 절대 금지) ===
# ⚠️ 정책 결정 필요: data/ 전체 무시 vs 하위 폴더만 무시
# 현재는 보수적으로 data/ 전체 무시 (PII·NDA 안전 우선)
data/
# (참고: 아래 세부 항목은 data/ 전체 무시 시 사실상 중복이지만,
#        명시성 차원에서 유지 — 정책 변경 시 data/ 줄만 삭제하면 즉시 활성화)
data/raw/
data/원본데이터/
data/files/
*.hwp
*.pdf
data_list.csv
data_list*.xlsx

# === 평가 산출물 (재생성 가능, 용량 관리) ===
eval_cache/
reports/*.tmp